{
  "name": "cybraferibot",
  "scripts": {
    "dev": "bun --hot index.ts",
    "start": "bun index.ts",
    "db:init": "bun db/bootstrap.ts",
    "db:push": "drizzle-kit push",
    "test": "bun test --preload ./test/preload.ts",
    "test:watch": "bun test --watch --preload ./test/preload.ts",
    "check": "bun x tsc --noEmit && bun test --preload ./test/preload.ts"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "compromise": "^14.15.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "hono": "^4.12.18",
    "mammoth": "^1.12.0",
    "openai": "^6.42.0",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  }
}
