# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# App server port
PORT=4129

# Enable Telegram Bot API 10.1 Rich Messages (streaming & native markdown)
# Set to false to use stable HTML fallback rendering
TELEGRAM_RICH_MESSAGES=false

# SQLite database path
DATABASE_URL=/app/data/sqlite.db

# Qdrant Database Configuration
# Leave QDRANT_API_KEY empty if running Qdrant locally without auth
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Backward-compatible alias if you already use GOOGLE_API_KEY
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: model for chat responses
GEMINI_MODEL=gemini-2.5-flash

# Optional: fallback model when main Gemini chat model is busy/unavailable
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Optional: cheaper model for intent classification
GEMINI_INTENT_MODEL=gemini-2.5-flash-lite

# Optional: model for PDF/image summarization and Q&A
GEMINI_DOCUMENT_MODEL=gemini-2.5-flash

# Optional: OpenAI-compatible provider for MiniMax / TokenRouter
OPENAI_API_KEY=your_tokenrouter_api_key_here
OPENAI_BASE_URL=https://api.tokenrouter.com/v1

# Optional: explicit TokenRouter aliases
TOKENROUTER_API_KEY=your_tokenrouter_api_key_here
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Optional: fallback OpenAI-compatible model if Gemini is unavailable
TOKENROUTER_FALLBACK_MODEL=tokenrouter:MiniMax-M3

# Optional: max upload size for Telegram document/image processing
DOCUMENT_MAX_BYTES=20971520

# Optional: token for admin config API
ADMIN_TOKEN=your_admin_token_here

# Required for Google login to the web app
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
PUBLIC_BASE_URL=https://cybrabot.ferilee.gurumuda.eu.org
SESSION_SECRET=replace_with_a_long_random_secret

# Optional: only this Telegram user can invoke the bot inside group chats
GROUP_ALLOWED_USER_ID=177517779
GROUP_ALLOWED_USERNAME=ferilee
